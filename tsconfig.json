{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /*
     * TS 6.0 changed the default of `types` from auto-including everything under
     * node_modules/@types to []. `src` uses Node globals (process.env in
     * ErrorBoundary, plus process/global/node:* builtins in the *.test files) so
     * we explicitly opt the Node types back in. vite/client types are pulled via
     * the /// <reference> in src/vite-env.d.ts and are unaffected by this list.
     */
    "types": ["node"],

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
