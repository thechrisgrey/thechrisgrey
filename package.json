{
  "name": "thechrisgrey",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "lambda/shared",
    "lambda/chat-stream",
    "lambda/blueprint",
    "lambda/kb-builder",
    "lambda/kb-sync",
    "lambda/metrics",
    "lambda/mcp-server",
    "lambda/session-token"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.js && node scripts/validate-endpoints.mjs && node scripts/generate-podcast-episodes.js && npm run lint && tsc && vite build && node scripts/generate-og-images.mjs && node scripts/prerender.js && node scripts/validate-prerender-seo.mjs && node scripts/generate-sitemap.js && node scripts/generate-rss.js",
    "build:analyze": "tsc && vite build && npx vite-bundle-visualizer",
    "bundle:size": "node scripts/track-bundle-size.mjs",
    "build:timed": "node scripts/track-build-performance.mjs",
    "build:compare": "node scripts/compare-build-performance.mjs",
    "lint": "eslint src --max-warnings 0",
    "lint:lambda": "eslint lambda --max-warnings 0",
    "tsc:lambda": "tsc --project lambda/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:agents": "node scripts/validate-agents-md.mjs",
    "validate:endpoints": "node scripts/validate-endpoints.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:lambda": "node --test --test-reporter=spec --test-reporter=junit --test-reporter-destination=stdout --test-reporter-destination=lambda-test-results.xml lambda/shared/__tests__/*.test.mjs lambda/blueprint/__tests__/*.test.mjs lambda/chat-stream/__tests__/*.test.mjs lambda/chat-stream/__tests__/tools/*.test.mjs lambda/mcp-server/__tests__/*.test.mjs lambda/metrics/__tests__/*.test.mjs lambda/kb-builder/__tests__/*.test.mjs lambda/kb-sync/__tests__/*.test.mjs lambda/session-token/__tests__/*.test.mjs",
    "test:lambda:coverage": "node scripts/check-lambda-coverage.mjs",
    "test:lambda:turbo": "turbo run test",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "deploy:lambda": "bash scripts/deploy-lambda.sh",
    "smoke:lambda": "node scripts/smoke-test-lambdas.mjs",
    "iam:drift": "bash scripts/iam-drift.sh",
    "test:flaky": "node scripts/detect-flaky-tests.mjs",
    "lint:quality": "node scripts/code-quality-report.mjs",
    "changelog": "node scripts/generate-changelog.mjs",
    "docs:api": "typedoc",
    "docs:openapi": "node scripts/generate-openapi-docs.mjs",
    "docs:gen": "npm run docs:api && npm run docs:openapi",
    "knip": "knip",
    "jscpd": "jscpd src lambda scripts",
    "check:tech-debt": "node scripts/check-tech-debt.mjs",
    "syncpack": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "check:dep-age": "node scripts/check-dependency-age.mjs",
    "check:feature-flags": "node scripts/check-dead-feature-flags.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1068.0",
    "@portabletext/react": "^6.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.0.2",
    "@sentry/react": "^10.65.0",
    "aws-rum-web": "^3.1.0",
    "dompurify": "^3.4.11",
    "gsap": "^3.14.2",
    "lenis": "^1.3.23",
    "mermaid": "^11.14.0",
    "posthog-js": "^1.386.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0",
    "shiki": "^4.2.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.14.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "jsdom": "^29.0.2",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.32",
    "prettier": "^3.9.4",
    "puppeteer": "^25.1.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.1",
    "svgo": "^4.0.0",
    "syncpack": "^15.3.2",
    "tailwindcss": "^4.3.1",
    "terser": "^5.44.1",
    "turbo": "2.10.3",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^4.1.9",
    "web-vitals": "^5.1.0",
    "yaml": "^2.9.0"
  }
}
