{
  "name": "thechrisgrey",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-env.js && node scripts/generate-podcast-episodes.js && npm run lint && tsc && vite build && node scripts/generate-og-images.mjs && node scripts/prerender.js && node scripts/generate-sitemap.js && node scripts/generate-rss.js",
    "build:analyze": "tsc && vite build && npx vite-bundle-visualizer",
    "lint": "eslint src --max-warnings 0",
    "lint:lambda": "eslint lambda --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:lambda": "node --test lambda/shared/__tests__/*.test.mjs lambda/blueprint/__tests__/*.test.mjs lambda/chat-stream/__tests__/*.test.mjs lambda/chat-stream/__tests__/tools/*.test.mjs lambda/mcp-server/__tests__/*.test.mjs lambda/metrics/__tests__/*.test.mjs lambda/kb-builder/__tests__/*.test.mjs lambda/kb-sync/__tests__/*.test.mjs lambda/session-token/__tests__/*.test.mjs",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "deploy:lambda": "bash scripts/deploy-lambda.sh",
    "smoke:lambda": "node scripts/smoke-test-lambdas.mjs",
    "iam:drift": "bash scripts/iam-drift.sh"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1000.0",
    "@portabletext/react": "^6.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.2",
    "dompurify": "^3.4.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.23",
    "mermaid": "^11.14.0",
    "posthog-js": "^1.386.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0",
    "shiki": "^4.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.8",
    "cypress": "^15.14.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.32",
    "puppeteer": "^24.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.44.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.0.8",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^4.1.8",
    "web-vitals": "^5.1.0"
  },
  "overrides": {
    "stats-gl": {
      "three": "$three"
    }
  }
}
