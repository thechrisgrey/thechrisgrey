{
  "threshold": 5,
  "reporters": ["console", "html"],
  "output": "./jscpd-report",
  "format": ["typescript", "javascript"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/test-results/**",
    "**/__fixtures__/**",
    "**/*.test.{ts,tsx,mjs}",
    "**/*.spec.{ts,tsx,mjs}",
    "**/cypress/**",
    "src/data/generatedEpisodes.json",
    "**/package-lock.json"
  ],
  "min-lines": 5,
  "min-tokens": 50
}
