# API Endpoints (set these to your Lambda Function URLs)
VITE_NEWSLETTER_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-2.on.aws/
VITE_CONTACT_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-2.on.aws/
VITE_CHAT_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-1.on.aws/

# Session tokens (replaces the retired bundled HMAC keys). The client fetches short-lived,
# scoped tokens from the session-token issuer Lambda after a Cloudflare Turnstile
# check, and sends them as `Authorization: Bearer`.
VITE_SESSION_ENDPOINT=https://YOUR-SESSION-FUNCTION-URL.lambda-url.us-east-1.on.aws/
# Cloudflare Turnstile SITE key (public — safe in the bundle). The matching SECRET
# key is server-only: set TURNSTILE_SECRET on the session-token Lambda, NEVER here.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# YouTube Data API v3 key (build-time only, not VITE_ prefixed)
# YOUTUBE_API_KEY=your-youtube-api-key

# KB Admin (Cognito)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_KB_BUILDER_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-1.on.aws/

# Site metrics / web-vitals + CSP-report Lambda (us-east-1)
VITE_METRICS_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-1.on.aws/

# PostHog product analytics (OPTIONAL — consent-gated, loads only after the visitor
# accepts the banner). The project API key is publishable/client-side (safe in the
# bundle). Leave unset to disable PostHog entirely (no banner, no cookies). Host
# defaults to https://us.i.posthog.com.
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# CloudWatch RUM error tracking (OPTIONAL — only active when APP_MONITOR_ID is
# set). Create a CloudWatch RUM App Monitor in us-east-1, note the App Monitor
# ID, and create a Cognito Identity Pool with unauthenticated access. Source maps
# are uploaded to S3 during the Amplify build for stack trace unminification.
# VITE_RUM_RELEASE_ID is auto-injected from the git commit hash at build time.
# VITE_RUM_APP_MONITOR_ID=your-app-monitor-id
# VITE_RUM_IDENTITY_POOL_ID=us-east-1:your-identity-pool-id
# VITE_RUM_REGION=us-east-1

# Blueprint (waitlist-only until launch; leave VITE_BLUEPRINT_ENABLED unset or "false" for placeholder page)
# VITE_BLUEPRINT_ENABLED=true
# VITE_BLUEPRINT_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-1.on.aws/
# VITE_BLUEPRINT_BUILDER_ENDPOINT=https://YOUR-FUNCTION-URL.lambda-url.us-east-1.on.aws/

# ──────────────────────────────────────────────────────────────────────────────
# Opt-in live-API CONTRACT tests (NOT used by the app or CI)
# ──────────────────────────────────────────────────────────────────────────────
# These node:test suites hit the REAL external boundaries the app otherwise only
# mocks, so a response-shape / schema drift fails loudly instead of shipping green.
# They skip cleanly (exit 0) unless their flag is set, so `npm run test:lambda`
# and CI never call AWS/Sanity. Run a suite by setting its flag (+ any required
# vars) for that command only — do NOT commit real values here.
#
#   # Cognito InitiateAuth -> /admin token shape (needs a dedicated test user):
#   COGNITO_CONTRACT_TESTS=1 COGNITO_CLIENT_ID=... COGNITO_TEST_EMAIL=... \
#     COGNITO_TEST_PASSWORD=... node --test lambda/shared/__tests__/cognito-contract.test.mjs
#
#   # Live @sanity/client + the real GROQ projections:
#   SANITY_CONTRACT_TESTS=1 node --test lambda/chat-stream/__tests__/sanity-contract.test.mjs
#
#   # Live Bedrock KB Retrieve (default KB_ID=ARFYABW8HP):
#   KB_RETRIEVE_CONTRACT_TESTS=1 node --test lambda/chat-stream/__tests__/kb-retrieve-contract.test.mjs
#
#   # Live Bedrock guardrail false-block regression (pre-existing):
#   BEDROCK_CONTRACT_TESTS=1 node --test lambda/blueprint/__tests__/guardrail-contract.test.mjs
#
# All require AWS credentials in the environment with the matching permissions
# (cognito-idp:InitiateAuth/GetUser, bedrock:Retrieve, bedrock:ApplyGuardrail).
