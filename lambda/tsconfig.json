{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "aws-lambda"],
    "lib": ["ES2022"],
    "paths": {
      "lambda-shared/*": ["./shared/*.mjs"]
    },
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false
  },
  "include": [
    "shared/**/*.mjs",
    "chat-stream/**/*.mjs",
    "blueprint/**/*.mjs",
    "kb-builder/**/*.mjs",
    "kb-sync/**/*.mjs",
    "metrics/**/*.mjs",
    "mcp-server/**/*.mjs",
    "session-token/**/*.mjs"
  ],
  "exclude": ["**/node_modules/**", "**/__tests__/**", "**/__fixtures__/**", "**/function.zip"]
}
