# Build artifacts for every Lambda (glob, so new Lambdas are covered automatically).
# NOTE: package-lock.json is intentionally NOT globbed — chat-stream and blueprint
# commit their lockfiles so CI can `npm ci`. Only kb-builder (npm install) ignores it.
lambda/*/node_modules/
lambda/*/function.zip
lambda/kb-builder/package-lock.json

